# Dashboard → Firebase Realtime Database connection.
# Copy to `.env` (or set these in Vercel → Project → Environment Variables).
# Get these values from Firebase console → Project settings → your Web App config.
# See FIREBASE_SETUP.md for the step-by-step.

VITE_FIREBASE_DATABASE_URL=https://YOUR_PROJECT-default-rtdb.firebaseio.com
VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT
VITE_FIREBASE_APP_ID=YOUR_APP_ID

# Optional — RTDB path devices write to (default "telemetry")
# VITE_FIREBASE_TELEMETRY_PATH=telemetry
