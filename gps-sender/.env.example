# Salin ke .env lalu isi. FIREBASE_DB_URL WAJIB.

# URL Realtime Database (dari Firebase console / rekan yang setup).
FIREBASE_DB_URL=https://YOUR_PROJECT-default-rtdb.firebaseio.com

# ID unit — samakan dengan daftar (MOTOR-001 … MOTOR-010).
DEVICE_ID=MOTOR-001

# Token Firebase — isi HANYA jika database memakai auth.
AUTH=

# Paket per detik.
RATE=1

# demo = koordinat buatan (tanpa hardware) · serial = GPS NMEA sungguhan
MODE=demo

# Hanya untuk MODE=serial:
SERIAL_PORT=
SERIAL_BAUD=9600
