# Salin ke .env lalu isi. API_URL WAJIB diisi.

# URL ingest server FleetTrack (dari rekan yang men-deploy server).
# Lokal:   http://localhost:4000/api/telemetry
# Tunnel:  https://xxxx.loca.lt/api/telemetry
# Deploy:  https://fleettrack-server.onrender.com/api/telemetry
API_URL=http://localhost:4000/api/telemetry

# ID unit — samakan dengan daftar di server (MOTOR-001 … MOTOR-010).
DEVICE_ID=MOTOR-001

# Isi HANYA jika server mengaktifkan INGEST_API_KEY.
API_KEY=

# Paket per detik.
RATE=1

# demo = koordinat buatan (tanpa hardware) · serial = GPS NMEA sungguhan
MODE=demo

# Hanya untuk MODE=serial:
SERIAL_PORT=
SERIAL_BAUD=9600
