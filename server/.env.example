# ── FleetTrack Manado — cloud server configuration ───────────────────────────
# Copy to `.env` and adjust. Everything has a sane default so the server runs
# out of the box (in-memory, HTTP ingest only). Enable MQTT / dual-DB when ready.

# HTTP + Socket.IO listen port
PORT=4000

# CORS origin allowed to connect (the dashboard dev server). Use * to allow all.
CORS_ORIGIN=http://localhost:5173

# Shared secret required in the `x-api-key` header for POST /api/telemetry.
# Leave empty to disable auth (development only).
INGEST_API_KEY=

# ── MQTT (device → server) ───────────────────────────────────────────────────
# Set MQTT_URL to subscribe to a broker (Mosquitto). Leave empty to disable and
# rely only on HTTP ingest (POST /api/telemetry). Devices publish to
#   rental/motor/{id}/telemetry   (QoS 1, JSON)
MQTT_URL=
# e.g. mqtt://localhost:1883  or  mqtts://broker.example.com:8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_TELEMETRY=rental/motor/+/telemetry
MQTT_TOPIC_HEARTBEAT=rental/system/heartbeat

# ── Persistence (optional dual-database, §III-E of the proposal) ──────────────
# STORE=memory (default) keeps state in RAM only.
# STORE=db persists relational state to PostgreSQL and time-series to InfluxDB.
STORE=memory

# PostgreSQL (relational: motorcycles, rentals, geofences, alerts)
PGHOST=localhost
PGPORT=5432
PGDATABASE=fleettrack
PGUSER=fleettrack
PGPASSWORD=

# InfluxDB (time-series: telemetry samples)
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=
INFLUX_ORG=fleettrack
INFLUX_BUCKET=telemetry
